{
  "expo": {
    "name": "Sanatan",
    "slug": "Sanatan",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.samarthbanodia.sanatan"
    },
    "android": {
      "package": "com.samarthbanodia.sanatan",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Sanatan to use the microphone so you can speak with the deities."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "cf7646c7-825a-4bfb-9754-c5c56ccda1f4"
      }
    },
    "owner": "c0mrade12"
  }
}
